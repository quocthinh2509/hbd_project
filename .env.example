# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://birthday_user:birthday_pass@localhost:5432/birthday_card

# Auth
API_KEY_SECRET=your-super-secret-api-key-256bit-random-string-here

# Puppeteer
PUPPETEER_CONCURRENCY=3
PUPPETEER_TIMEOUT_MS=30000

# Storage (optional – nếu dùng S3)
S3_BUCKET=birthday-card-templates
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Avatar whitelist domains (comma-separated, không có dấu cách)
AVATAR_ALLOWED_DOMAINS=hrm.fpt.vn,storage.fpt.vn

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
